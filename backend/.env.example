# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# Modal (project account — NOT per-user)
MODAL_TOKEN_ID=ak-xxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxx

# Webhook HMAC secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
WEBHOOK_SECRET=your-64-char-hex-secret

# Callback URL (your deployed FastAPI URL)
CALLBACK_BASE_URL=https://your-api.railway.app

# HuggingFace (project account)
HF_TOKEN=hf_xxxxxxxxxxxx
